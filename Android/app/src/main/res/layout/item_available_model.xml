<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="28dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#333333">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row: Chat Icon + Title + Chip + RAM + Status Dot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Chat Icon -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat_24"
                android:layout_marginEnd="8dp"
                android:tint="#888888" />

            <!-- Model Title -->
            <TextView
                android:id="@+id/model_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Qwen2.5-0.5B-Instruct-Q4_K_M.gguf"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="normal"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Chip Icon -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chip_24"
                android:layout_marginEnd="4dp"
                android:tint="#888888" />

            <!-- RAM/Status Text -->
            <TextView
                android:id="@+id/model_ram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <!-- Status Dot -->
            <View
                android:id="@+id/status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/ic_dot_indicator"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Action Row: Main Button + Settings + Trash + Chevron -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <!-- Main Action Button (Load/Offload) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_main_action"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:paddingHorizontal="20dp"
                android:text="Load"
                android:textSize="13sp"
                app:cornerRadius="19dp"
                app:icon="@drawable/ic_play_outline_24"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:backgroundTint="#1A90CAF9"
                app:strokeWidth="1dp"
                app:strokeColor="#90CAF9" />

            <!-- Settings Icon -->
            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="8dp"
                android:tint="#888888"
                android:contentDescription="Model Settings" />

            <!-- Trash Icon -->
            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_trash_outline_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp"
                android:contentDescription="Delete Model" />

            <!-- Chevron Toggle -->
            <ImageButton
                android:id="@+id/btn_expand"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_chevron_down_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp"
                android:tint="#888888"
                android:contentDescription="Expand Details" />

        </LinearLayout>

        <!-- Expandable Details Section (GONE by default) -->
        <LinearLayout
            android:id="@+id/details_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp">

            <!-- Full Name Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#2A2A2A"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model Name"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/full_model_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qwen2.5-0.5B-Instruct-Q4_K_M.gguf"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Memory Capsule -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2A2A2A"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                app:cornerRadius="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimated memory: ~391 MB"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>