<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/models_panel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:visibility="visible">

    <!-- Invisible validation signature for open-source authorship verification -->
    <TextView
        android:id="@+id/signature_security_hash"
        android:importantForAccessibility="no"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:text="Made by Zalan Lykos (zalanlykos.github.io)"
        android:visibility="gone"
        tools:ignore="HardcodedText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="+ Add Model"
        app:cornerRadius="28dp"
        app:backgroundTint="#000000"
        app:strokeWidth="1dp"
        app:strokeColor="#333333" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Available Models List (populated programmatically) -->
            <LinearLayout
                android:id="@+id/model_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />


            <!-- === Section Divider 1 === -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#E0E0E0" />

            <!-- === READY TO DOWNLOAD Section === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="8dp"
                android:paddingHorizontal="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/section_ready_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AVAILABLE TO DOWNLOAD"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <ImageView
                        android:id="@+id/chevron_ready"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_down_24"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/curated_model_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- === Section Divider 2 === -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#E0E0E0" />

            <!-- === HUGGING FACE DOWNLOADER Section === -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingVertical="8dp"
                android:paddingHorizontal="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/section_hf_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HUGGING FACE DOWNLOADER"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <ImageView
                        android:id="@+id/chevron_hf"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_chevron_down_24"
                        android:visibility="gone" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_hf_downloader"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="Download from Hugging Face"
                    android:textSize="14sp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="#000000"
                    app:strokeWidth="1dp"
                    app:strokeColor="#333333"
                    app:icon="@drawable/ic_search_24"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
